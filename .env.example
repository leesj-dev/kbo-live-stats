# Neon Postgres connection string (use the pooled connection URL)
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Shared secret used to authorize the daily cron endpoint.
# Vercel Cron automatically sends this as `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET="generate-a-long-random-string"
